---
// src/components/Projects.astro
import AiTool from "./AiTool.astro";
---

<section
  id="projects"
  class="w-full mx-auto py-24 border-t border-slate-800/50"
>
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="mb-16 text-center md:text-left">
      <h2
        class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-indigo-500 mb-4 flex items-center gap-3 justify-center md:justify-start"
      >
        <span class="text-cyan-500">#</span> Featured Projects
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto md:mx-0">
        Here are some of the projects I've been working on, ranging from
        full-stack applications to AI-powered APIs.
      </p>
    </div>

    <div class="space-y-32">
      <div class="flex flex-col xl:flex-row gap-12 items-start">
        <div class="xl:w-1/3 flex flex-col space-y-6">
          <div>
            <h3 class="text-3xl font-bold text-white mb-4">AI Creator API</h3>
            <p class="text-slate-300 leading-relaxed text-lg">
              An experimental backend service deployed on Render that leverages
              Hugging Face models to process and generate text for content
              creators. It features four distinct endpoints: summarizing long
              texts, generating viral titles, extracting hashtags, and
              translating content to English.
            </p>
          </div>

          <div class="flex flex-wrap gap-2">
            <span
              class="px-3 py-1 bg-cyan-500/10 text-cyan-400 text-sm rounded-md font-bold border border-cyan-500/20"
              >FastAPI</span
            >
            <span
              class="px-3 py-1 bg-indigo-500/10 text-indigo-400 text-sm rounded-md font-bold border border-indigo-500/20"
              >Hugging Face</span
            >
            <span
              class="px-3 py-1 bg-blue-500/10 text-blue-400 text-sm rounded-md font-bold border border-blue-500/20"
              >Python</span
            >
          </div>

          <div class="pt-4">
            <a
              href="https://github.com/otto616/ai-creator-api"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white rounded-xl transition-all duration-300 border border-slate-700 font-medium shadow-lg hover:shadow-cyan-500/20 group"
            >
              <svg
                class="w-6 h-6 group-hover:scale-110 transition-transform"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  clip-rule="evenodd"></path>
              </svg>
              View Repository
            </a>
          </div>
        </div>

        <div class="xl:w-2/3 w-full">
          <AiTool />
        </div>
      </div>

      <div class="flex flex-col xl:flex-row-reverse gap-12 items-start">
        <div class="xl:w-1/3 flex flex-col space-y-6">
          <div>
            <h3 class="text-3xl font-bold text-white mb-4">DealHunter</h3>
            <p class="text-slate-300 leading-relaxed text-lg">
              A robust web platform engineered to centralize and compare digital
              video game offers. Developed with a strong focus on structured
              data, it implements semantic markup (RDFa) to optimize web
              scraping efficiency and search engine indexing.
            </p>
          </div>

          <div class="flex flex-wrap gap-2">
            <span
              class="px-3 py-1 bg-green-500/10 text-green-400 text-sm rounded-md font-bold border border-green-500/20"
              >Django</span
            >
            <span
              class="px-3 py-1 bg-blue-500/10 text-blue-400 text-sm rounded-md font-bold border border-blue-500/20"
              >Python</span
            >
            <span
              class="px-3 py-1 bg-purple-500/10 text-purple-400 text-sm rounded-md font-bold border border-purple-500/20"
              >RDFa</span
            >
            <span
              class="px-3 py-1 bg-orange-500/10 text-orange-400 text-sm rounded-md font-bold border border-orange-500/20"
              >HTML</span
            >
            <span
              class="px-3 py-1 bg-sky-500/10 text-sky-400 text-sm rounded-md font-bold border border-sky-500/20"
              >CSS</span
            >
            <span
              class="px-3 py-1 bg-yellow-500/10 text-yellow-400 text-sm rounded-md font-bold border border-yellow-500/20"
              >PostgreSQL</span
            >
          </div>

          <div class="pt-4">
            <a
              href="https://github.com/otto616/teu-repo-dealhunter"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white rounded-xl transition-all duration-300 border border-slate-700 font-medium shadow-lg hover:shadow-green-500/20 group"
            >
              <svg
                class="w-6 h-6 group-hover:scale-110 transition-transform"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  clip-rule="evenodd"></path>
              </svg>
              View Repository
            </a>
          </div>
        </div>

        <div class="xl:w-2/3 w-full group">
          <div
            class="relative rounded-2xl overflow-hidden border border-slate-800 bg-slate-900 shadow-2xl transition-all duration-500 group-hover:border-slate-600 group-hover:shadow-green-500/10"
          >
            <img
              src="/dealhunter.png"
              alt="DealHunter Platform Interface"
              class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-[1.02]"
              onerror="this.src='https://via.placeholder.com/800x450/0f172a/334155?text=DealHunter+Screenshot+Placeholder'"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
