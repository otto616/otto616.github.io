---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 border-t border-slate-800 mt-auto py-8 text-slate-400">
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-center">
        <!-- Left Side: Copyright -->
        <p class="text-sm">
            &copy; {currentYear} Otto. All rights reserved.
        </p>

        <!-- Right Side: Links with Icons -->
        <div class="flex flex-wrap justify-center gap-6 mt-4 md:mt-0 text-sm">
            <a 
                href="https://github.com/otto616" 
                target="_blank" 
                rel="noopener noreferrer" 
                class="flex items-center gap-2 hover:text-white transition-colors duration-300"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3-.3 6-1.5 6-6.5a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 5 3 6.2 6 6.5a4.8 4.8 0 0 0-1 3.2v4"/>
                    <path d="M9 18c-4.5 1.6-5-2.5-5.1-2.7"/>
                </svg>
                GitHub
            </a>
            
            <a 
                href="https://linkedin.com/in/otto616" 
                target="_blank" 
                rel="noopener noreferrer" 
                class="flex items-center gap-2 hover:text-[#0a66c2] transition-colors duration-300"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                    <rect width="4" height="12" x="2" y="9"/>
                    <circle cx="4" cy="4" r="2"/>
                </svg>
                LinkedIn
            </a>
            
            <a 
                href="https://instagram.com/otto.616" 
                target="_blank" 
                rel="noopener noreferrer" 
                class="flex items-center gap-2 hover:text-[#E1306C] transition-colors duration-300"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                    <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                    <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                </svg>
                Instagram
            </a>
            
            <a 
                href="mailto:ottobielrodenas@gmail.com" 
                class="flex items-center gap-2 hover:text-blue-400 transition-colors duration-300"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                    <rect width="20" height="16" x="2" y="4" rx="2"/>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
                Email
            </a>
        </div>
    </div>
</footer>