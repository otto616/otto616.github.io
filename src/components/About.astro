---
// src/components/About.astro
---

<section id="about" class="py-24 border-t border-slate-800/50">
    <div class="container mx-auto px-6 max-w-6xl">
        <div class="mb-16 text-center md:text-left">
            <h2
                class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-500 mb-4 flex items-center gap-3 justify-center md:justify-start"
            >
                <span class="text-blue-500">#</span> About & Experience
            </h2>
        </div>

        <div
            class="grid md:grid-cols-2 gap-12 text-slate-400 leading-relaxed text-lg"
        >
            <div class="space-y-6">
                <p>
                    I am currently in my third year of the Computer Engineering
                    Degree at the University of Lleida, focusing heavily on
                    Artificial Intelligence and Computation.
                </p>
                <p>
                    My approach to software development combines solid
                    theoretical foundations with practical engineering. I am
                    deeply interested in system architecture, self-improving
                    algorithms, and building robust backend platforms.
                </p>
            </div>

            <div>
                <h3 class="text-xl font-semibold text-slate-200 mb-6">
                    Core Technologies
                </h3>
                <div class="flex flex-wrap gap-3">
                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg"
                            alt="Python"
                            class="w-5 h-5 shrink-0"
                        />
                        <span class="font-medium">Python</span>
                    </div>

                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/c/c-original.svg"
                            alt="C"
                            class="w-5 h-5 shrink-0"
                        />
                        <span class="font-medium">C</span>
                    </div>

                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg"
                            alt="Java"
                            class="w-5 h-5 shrink-0"
                        />
                        <span class="font-medium">Java</span>
                    </div>

                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg"
                            alt="JavaScript"
                            class="w-5 h-5 shrink-0"
                        />
                        <span class="font-medium">JavaScript</span>
                    </div>

                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/django/django-plain.svg"
                            alt="Django"
                            class="w-5 h-5 shrink-0"
                        />
                        <span class="font-medium">Django</span>
                    </div>

                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/linux/linux-original.svg"
                            alt="Linux"
                            class="w-5 h-5 shrink-0"
                        />
                        <span class="font-medium">Linux</span>
                    </div>

                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg"
                            alt="Docker"
                            class="w-5 h-5 shrink-0"
                        />
                        <span class="font-medium">Docker</span>
                    </div>

                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/amazonwebservices/amazonwebservices-original-wordmark.svg"
                            alt="AWS"
                            class="w-auto h-5 object-contain shrink-0"
                        />
                        <span class="font-medium">AWS</span>
                    </div>

                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg"
                            alt="Astro"
                            class="w-5 h-5 shrink-0"
                        />
                        <span class="font-medium">Astro</span>
                    </div>

                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg"
                            alt="Tailwind CSS"
                            class="w-5 h-5 shrink-0"
                        />
                        <span class="font-medium">Tailwind CSS</span>
                    </div>

                    <div
                        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 rounded-lg text-sm text-slate-300 hover:border-slate-700 transition-colors cursor-default"
                    >
                        <img
                            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg"
                            alt="Git"
                            class="w-5 h-5 shrink-0"
                        />
                        <span class="font-medium">Git / CI/CD</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
