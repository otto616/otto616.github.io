---
// src/components/Hero.astro
---

<section
    class="min-h-[85vh] flex flex-col items-center justify-center p-8 text-center"
>
    <div class="container mx-auto flex flex-col items-center max-w-4xl">
        <div
            class="w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden border-4 border-slate-700 shadow-2xl mb-6 aspect-square bg-slate-800 flex items-center justify-center"
        >
            <img
                src="/profile.png"
                alt="Otto Biel Ródenas profile picture"
                class="w-full h-full object-cover"
                onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');"
            />
            <span
                class="hidden text-4xl text-slate-500 font-bold uppercase tracking-wider"
                >OB</span
            >
        </div>

        <p
            class="text-xl md:text-2xl font-medium text-slate-400 mb-2 tracking-wide"
        >
            Otto Biel Ródenas
        </p>

        <h1
            class="text-4xl sm:text-5xl md:text-7xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-500 mb-8 leading-tight tracking-tight"
        >
            Computer Engineer & Software Developer
        </h1>

        <p
            class="text-lg md:text-xl text-slate-300 font-normal max-w-2xl text-center leading-relaxed mb-12"
        >
            I am a software engineering and computer science student,
            specialized in the AI and computation branch. I am passionate about
            creating innovative solutions that make a difference in the world.
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-8">
            <a
                href="/cv_otto.pdf"
                download
                class="px-8 py-3.5 bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-600 text-white font-bold rounded-full shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40 transition-all duration-300 transform hover:-translate-y-0.5 active:translate-y-0 text-base flex items-center gap-2"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" x2="12" y1="15" y2="3"></line>
                </svg>
                Download CV
            </a>

            <div class="flex items-center gap-6 text-slate-400">
                <a
                    href="https://github.com/otto616"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-white transition-colors duration-300 p-1 hover:scale-110 transform"
                    title="GitHub Profile"
                >
                    <span class="sr-only">GitHub</span>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3-.3 6-1.5 6-6.5a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 5 3 6.2 6 6.5a4.8 4.8 0 0 0-1 3.2v4"
                        ></path>
                        <path d="M9 18c-4.5 1.6-5-2.5-5.1-2.7"></path>
                    </svg>
                </a>

                <a
                    href="https://linkedin.com/in/yourusername"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-[#0a66c2] transition-colors duration-300 p-1 hover:scale-110 transform"
                    title="LinkedIn Profile"
                >
                    <span class="sr-only">LinkedIn</span>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                        ></path>
                        <rect width="4" height="12" x="2" y="9"></rect>
                        <circle cx="4" cy="4" r="2"></circle>
                    </svg>
                </a>

                <a
                    href="https://instagram.com/yourusername"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-[#E1306C] transition-colors duration-300 p-1 hover:scale-110 transform"
                    title="Instagram Profile"
                >
                    <span class="sr-only">Instagram</span>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect width="20" height="20" x="2" y="2" rx="5" ry="5"
                        ></rect>
                        <path
                            d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                        ></path>
                        <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
                    </svg>
                </a>

                <a
                    href="mailto:youremail@gmail.com"
                    class="hover:text-blue-400 transition-colors duration-300 p-1 hover:scale-110 transform"
                    title="Send Email"
                >
                    <span class="sr-only">Email</span>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</section>
