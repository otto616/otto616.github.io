---
// src/components/Navbar.astro
---

<header
    class="fixed top-0 w-full z-50 bg-slate-950/80 backdrop-blur-md border-b border-slate-800"
>
    <div class="w-full px-4 md:px-8 py-4 flex justify-between items-center">
        <a
            href="#"
            class="flex items-center gap-2 group"
            aria-label="Return on top"
            title="Return on top"
        >
            <div
                class="w-10 h-10 rounded-full bg-slate-800 border border-slate-700 overflow-hidden flex items-center justify-center group-hover:border-blue-500 transition-colors shadow-lg"
            >
                <img
                    src="/logo.png"
                    alt="Logo"
                    class="w-full h-full object-cover"
                    onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');"
                />
                <span
                    class="hidden text-sm font-bold text-slate-300 group-hover:text-blue-400 transition-colors"
                    >OB</span
                >
            </div>
        </a>

        <nav class="flex space-x-10 text-sm font-semibold text-slate-300 pr-2">
            <a
                href="#about"
                class="hover:text-white transition-colors duration-300">About</a
            >
            <a
                href="#projects"
                class="hover:text-white transition-colors duration-300"
                >Projects</a
            >
        </nav>
    </div>
</header>
